NODE_ENV=development
PORT=4000

# Postgres — reuses your existing local Postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=playswell
DB_USER=postgres
DB_PASSWORD=noexer_dev_password

# CORS — allow local frontend dev and GitHub Pages
ALLOWED_ORIGINS=http://localhost:5174,http://localhost:3000,https://andreruizloera.github.io

# Pokemon TCG API (no key needed for 20k/day free tier)
POKEMON_TCG_BASE=https://api.pokemontcg.io/v2
POKEMON_TCG_KEY=

# Rebrickable (free key required — get one at rebrickable.com/api/)
REBRICKABLE_BASE=https://rebrickable.com/api/v3
REBRICKABLE_KEY=

# Fee config
FEE_PERCENT=0.04
FEE_FIXED=0.50
CAUSE_SPLIT=0.60
